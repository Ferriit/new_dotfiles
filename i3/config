# Swedish (US) layout: US keys, Right Alt → å ä ö

# Mod key
set $mod Mod4
font pango:MapleMono Nerd Font 9

# exec_always --no-startup-id xrandr --output HDMI-0 --primary --auto --pos 0x0 --output DP-2.8 --auto --rotate left --pos 1920x0
exec_always --no-startup-id xrandr \
  --output DP-2.8 --primary --auto --pos 0x0 \
  --output HDMI-0 --auto --right-of DP-2.8

exec_always --no-startup-id setxkbmap -layout se -variant us

focus_on_window_activation smart

# Autostart apps
exec_always --no-startup-id dunst
exec_always --no-startup-id ~/.config/polybar/launch.sh
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id nm-applet
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id export GTK_THEME=Catppuccin-Mocha-Standard-Mauve-Dark

exec_always --no-startup-id picom

# Dualsense touchpad fix
exec --no-startup-id xinput disable "Sony Interactive Entertainment DualSense Wireless Controller Touchpad"


# Gaps & borders
gaps outer 10
gaps inner 10
for_window [class="^.*"] border pixel 2

#for_window [class="firefox"] floating disable
#for_window [class="Spotify"] floating disable
#for_window [class="vesktop"] floating disable

exec_always --no-startup-id feh /home/ferriit/Pictures/wallpapers/Clearnight.jpg --bg-fill

exec_always --no-startup-id xset s off -dpms


# Colors (Catppuccin Mocha)
client.focused          #cba6f7 #1e1e2e #cdd6f4 #b4befe #cba6f7
client.focused_inactive #313244 #1e1e2e #a6adc8 #45475a #313244
client.unfocused        #313244 #181825 #a6adc8 #313244 #181825
client.urgent           #f38ba8 #1e1e2e #f5e0dc #f38ba8 #f38ba8
client.placeholder      #1e1e2e #1e1e2e #cdd6f4 #1e1e2e #1e1e2e

# Lockscreen
bindsym $mod+Shift+x exec i3lock --blur 5 \
  --inside-color=1e1e2eFF \
  --ring-color=cba6f7FF \
  --line-color=00000000 \
  --keyhl-color=89b4faFF \
  --bshl-color=f38ba8FF \
  --separator-color=00000000 \
  --insidever-color=89b4faFF \
  --insidewrong-color=f38ba8FF \
  --ringver-color=89b4faFF \
  --ringwrong-color=f38ba8FF

# Dmenu / Rofi
bindsym $mod+w exec rofi -show drun
bindsym $mod+d exec --no-startup-id dmenu_run -nb '#1e1e2e' -nf '#cdd6f4' -sb '#cba6f7' -sf '#1e1e2e' -fn 'MapleMono Nerd Font-9'

# Audio / Volume
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

bindsym $mod+Shift+g exec pactl set-source-volume 58 400%
bindsym $mod+Shift+b exec pactl set-source-volume 58 50%
bindsym $mod+g exec pamixer --increase 5
bindsym $mod+b exec pamixer --decrease 5

# Floating / Dragging
floating_modifier $mod
tiling_drag modifier titlebar

# Terminals
bindsym $mod+Return exec --no-startup-id /home/ferriit/bash_term.sh
bindsym $mod+Shift+Return exec --no-startup-id /home/ferriit/htop_term.sh
bindsym $mod+t exec --no-startup-id kitty
bindsym $mod+Shift+t exec --no-startup-id alacritty
bindsym $mod+e exec --no-startup-id nemo

# Window management (US keys)
bindsym $mod+q kill

exec_always sudo modprobe v4l2loopback devices=1 video_nr=2 card_label="OBS Virtual Camera" exclusive_caps=1

# Focus window
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Move window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Focus window with arrows
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move window with arrows
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

bindsym $mod+v split v
bindsym $mod+s layout stacking
bindsym $mod+c layout tabbed
bindsym $mod+f fullscreen toggle
bindsym $mod+z layout toggle split
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent

